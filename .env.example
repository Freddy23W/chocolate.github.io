# GitHub API token for local automation (do not commit your real .env)
#
# Create a fine-grained PAT (recommended) with at least:
# - Actions: Read and write
# - Contents: Read and write
# - Pull requests: Read and write
#
# Alternatively, set GH_PR_TOKEN for PR creation flows.
GH_TOKEN=

# Optional override for owner/repo (otherwise inferred from .git/config origin remote)
# GH_REPO=owner/repo

# Default ref for workflow dispatch
GH_REF=main

# For GitHub Enterprise Server, override this
GH_API_URL=https://api.github.com
